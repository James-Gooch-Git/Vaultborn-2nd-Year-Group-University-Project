    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/newbackground.png"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ResizeSidebar" MinWidth="0" Width="220"/>
            <ColumnDefinition x:Name="ResizeSidebarThumb" Width="15"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="ModelDataSidebarThumb" Width="0"/>
            <ColumnDefinition x:Name="ModelDataSidebar" MinWidth="0" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- left thumb -->
        <Thumb Grid.Row="1" Grid.Column="1" Width="5" Cursor="SizeWE" DragDelta="ResizeSidebarThumb_DragDelta" Margin="-16,0,0,0" Canvas.ZIndex="999">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" Width="15"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>


        <Border Grid.Row="0" Grid.ColumnSpan="5" BorderBrush="#98730c" BorderThickness="0,0,0,1">
            <!-- <Border.Background>
                <ImageBrush ImageSource="\Assets\ScaleBackground.png" Stretch="UniformToFill" />
            </Border.Background> -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="\Assets\AppIcon4.png" Width="62" Height="45"/>
                    <TextBlock FontSize="16" Foreground="#E0E0E0" VerticalAlignment="Center" Height="18" Margin="-10,0,0,0"><Run Text="VAULTBORN"/><Run Text=" "/><Bold><Run Text="TREASURES"/></Bold></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border MouseLeftButtonDown="Refresh_Click" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                        <md:PackIcon Grid.Column="1" Kind="Sync" Foreground="#d1d5db" Style="{StaticResource IconHover}" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Border>

                    <Border x:Name="Bell" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="Bell_Click">
                        <md:PackIcon x:Name="BellIcon" Grid.Column="1" Foreground="#d1d5db" Kind="BellOutline" Style="{StaticResource IconHover}" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Border>

                    <Popup x:Name="NotificationsPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=Bell}" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-250">
                        <Border x:Name="NotificationCentre" Background="#540754" CornerRadius="5"
                                Width="300" Height="300">
                            <!-- <Border.Effect>
                                <DropShadowEffect BlurRadius="50" ShadowDepth="10" Color="Black" Opacity="0.2"/>
                            </Border.Effect> -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <!-- Header -->
                                    <RowDefinition Height="*"/>
                                    <!-- Notifications -->
                                    <RowDefinition Height="30"/>
                                    <!-- Clear all -->
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="#d1d5db" Text="Notifications" VerticalAlignment="Center" Margin="5"/>

                                <ListBox Grid.Row="1" x:Name="NotificationsListBox" Background="#540754" BorderBrush="Transparent" BorderThickness="0" MaxWidth="300" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#98730C" BorderThickness="0,1,0,1">
                                                <Grid Margin="5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding Id}" Visibility="Collapsed" x:Name="NotificationId"/>
                                                    <md:PackIcon Grid.Column="0" Kind="Circle" Foreground="#d1d5db" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="#d1d5db" TextWrapping="Wrap" MinWidth="275" MaxWidth="275" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Grid.Row="2" BorderBrush="#98730C" BorderThickness="3" CornerRadius="2" Width="80" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
                                    <Button Click="ClearNotifications_Click" Content="Clear All" Width="80" Height="25" BorderBrush="#98730C" BorderThickness="2" Background="#540754" Foreground="#d1d5db" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>

                    <Rectangle Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Fill="#d1d5db" Height="30" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                        <Rectangle.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="-1"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,5,0">
                        <Image x:Name="UserPic_Image" Width="42" Height="42"/>
                    </Border>

                    <Grid x:Name="User_Grid" Cursor="Hand" MouseLeftButtonDown="Chevron_Click" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal" MouseLeftButtonDown="Chevron_Click" HorizontalAlignment="Center" VerticalAlignment="Center">
                            
                            <TextBlock Grid.Column="1" MouseLeftButtonDown="Chevron_Click" x:Name="Username_TextBlock" FontSize="12" Foreground="#d1d5db" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            <Border Background="Transparent" MouseLeftButtonDown="Chevron_Click" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">

                                <!-- Chevron Icon -->
                                <md:PackIcon x:Name="ChevronDownClick" Kind="ChevronDown" Foreground="#d1d5db" VerticalAlignment="Center" HorizontalAlignment="Right" Cursor="Hand" MouseLeftButtonDown="Chevron_Click"/>

                            </Border>

                        </StackPanel>

                        <!-- Popup for Logout Menu -->
                        <Popup x:Name="ChevronPopupMenu" Placement="Bottom" PlacementTarget="{Binding ElementName=ChevronDownClick}"
       StaysOpen="True" AllowsTransparency="True" VerticalOffset="5">

                            <Border Background="#540754" CornerRadius="5" BorderBrush="#98730C" BorderThickness="2" Padding="8"
            Width="120">

                                <StackPanel>
                                    <Button Content="Logout" Click="BtnLogout_Click" 
                    Background="#98730C" Foreground="White" BorderBrush="#98730C" 
                    BorderThickness="2" Width="100" Height="30" Cursor="Hand"/>
                                </StackPanel>

                            </Border>

                        </Popup>


                    </Grid>

                </StackPanel>

            </Grid>

        </Border>


        <Border x:Name="ProjectsBorder" Grid.Row="1" Grid.Column="0" BorderBrush="#98730c" BorderThickness="0,0,1,0" Padding="5,0,5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Hubs Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Projects Header -->
                    <RowDefinition Height="*"/>
                    <!-- TreeView -->
                </Grid.RowDefinitions>

                <!-- Hubs Selection Header -->
                <Border Grid.Row="0" Background="Transparent" BorderBrush="#98730c" BorderThickness="0,0,0,1" Padding="5" Margin="-5,0,-5,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Dynamic Hubs Header -->
                        <TextBlock x:Name="HubsHeaderTextBlock" Text="Hubs - (Loading...)" 
                           FontSize="12" Foreground="#d1d5db" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>

                        <!-- Dropdown Arrow for Selecting a Hub -->
                        <Border x:Name="HubsDropdownBorder" Grid.Column="1" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Right" MouseLeftButtonDown="ToggleHubsMenu">
                            <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#d1d5db" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Cursor="Hand"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Popup for Hubs Selection -->
                <Popup x:Name="HubsMenuPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=HubsDropdownBorder}" StaysOpen="False" AllowsTransparency="True" VerticalOffset="5">
                    <Border Background="#540754" CornerRadius="5" BorderBrush="#98730C" BorderThickness="2" Padding="8" Width="Auto" Height="Auto">
                        <StackPanel x:Name="HubsMenuStackPanel" Margin="5"/>
                    </Border>
                </Popup>

                <!-- Projects Header -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left" 
                            MouseEnter="TextBlockBorder_Enter" MouseLeave="TextBlockBorder_Leave" Cursor="Hand" Margin="5,8,0,0" Grid.Column="0">
                        <TextBlock MouseLeftButtonDown="ProjectsText_Click" Text="PROJECTS" FontSize="12" Foreground="#d1d5db" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Height="16" Width="57"/>
                    </Border>

                    <!--<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">-->
                    <Button Click="CreateNewFolder_Click" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,5,0,0" HorizontalAlignment="Right" Grid.Column="1">
                        <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light" Kind="Plus" Style="{StaticResource IconHover}" Height="16" Width="16" Foreground="#d1d5db"/>
                    </Button>

        
                        <!--<Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" 
                        HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" 
                        Cursor="Hand" Margin="0,5,2,0">
                            <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light" 
                                 Kind="Plus" Style="{StaticResource IconHover}" Height="16" Width="16" Foreground="#d1d5db"/>
                        </Border>-->
                    <!--</StackPanel>-->
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" FlowDirection="RightToLeft" Padding="0" Margin="0">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    
