<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="300" Width="400">
    
    <Grid>
        <!-- Define Grid Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Upload Button -->
            <RowDefinition Height="Auto"/> <!-- Model Dropdown -->
            <RowDefinition Height="Auto"/> <!-- Refresh Button -->
        </Grid.RowDefinitions>

        <!-- Upload File Button -->
        <Button x:Name="BtnUploadFile" 
                Content="Upload File" 
                Width="200" Height="40" 
                Click="BtnUploadFile_Click"
                Grid.Row="0"/>

        <!-- Model Dropdown -->
        <ComboBox x:Name="ModelDropdown" Width="300" Height="30" Grid.Row="1" Margin="0,10,0,0"/>

        <!-- Refresh Models Button -->
        <Button x:Name="BtnRefreshModels" 
                Content="Refresh Models" 
                Width="150" Height="30" 
                Click="BtnRefreshModels_Click"
                Grid.Row="2" Margin="0,10,0,0"/>

    </Grid>
</Window>