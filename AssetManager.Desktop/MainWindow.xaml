    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ResizeSidebar" MinWidth="220" Width="Auto"/>
            <!--<ColumnDefinition Width="5"/>-->
            <ColumnDefinition Width="*"/>
            <!--<ColumnDefinition Width="5"/>-->
            <ColumnDefinition x:Name="ModelDataSidebar" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Row="0" Grid.ColumnSpan="4" BorderBrush="#797979" BorderThickness="0,0,0,1">
            <Border.Background>
                <ImageBrush ImageSource="\Assets\ScaleBackground.png" Stretch="UniformToFill" />
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="\Assets\AppIcon4.png" Width="62" Height="45"/>
                    <TextBlock FontSize="16" Foreground="#E0E0E0" VerticalAlignment="Center" Height="18" Margin="-10,0,0,0"><Run Text="VAULTBORN"/><Run Text=" "/><Bold><Run Text="TREASURES"/></Bold></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border MouseLeftButtonDown="Refresh_Click" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                        <md:PackIcon Grid.Column="1" Kind="Sync" Foreground="#d1d5db" Style="{StaticResource IconHover}" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Border>
                    
                    <Border x:Name="Bell" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0" MouseLeftButtonDown="Bell_Click">
                        <md:PackIcon Grid.Column="1" Foreground="#d1d5db" Kind="BellOutline" Style="{StaticResource IconHover}" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Border>
                    
                    <Popup x:Name="NotificationsPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=Bell}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-250">
                        <Border x:Name="NotificationCentre" Background="#5c1c1c" CornerRadius="5"
                                Width="300" Height="300">
                            <!-- <Border.Effect>
                                <DropShadowEffect BlurRadius="50" ShadowDepth="10" Color="Black" Opacity="0.2"/>
                            </Border.Effect> -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/> <!-- Header -->
                                    <RowDefinition Height="*"/> <!-- Notifications -->
                                    <RowDefinition Height="30"/> <!-- Clear all -->
                                </Grid.RowDefinitions>
                                
                                <TextBlock Foreground="#d1d5db" Text="Notifications" VerticalAlignment="Center" Margin="5"/>
                                
                                <ListBox Grid.Row="1" x:Name="NotificationsListBox" Background="#5c1c1c" BorderBrush="Transparent" BorderThickness="0" MaxWidth="300" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#98730C" BorderThickness="0,1,0,1">
                                                <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                    <TextBlock Text="{Binding Id}" Visibility="Collapsed" x:Name="NotificationId"/>
                                                    <md:PackIcon Grid.Column="0" Kind="Circle" Foreground="#d1d5db" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="#d1d5db" TextWrapping="Wrap" MinWidth="275" MaxWidth="275" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <Border Grid.Row="2" BorderBrush="#98730C" BorderThickness="3" CornerRadius="2" Width="80" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
                                    <Button Click="ClearNotifications_Click" Content="Clear All" Width="80" Height="25" BorderBrush="#98730C" BorderThickness="2" Background="#540754" Foreground="#d1d5db" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>

                    <Rectangle Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Fill="#d1d5db" Height="30" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                        <Rectangle.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="-1"/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,5,0">
                        <Image x:Name="UserPic_Image" Width="20" Height="20"/>
                    </Border>

                    <Grid x:Name="User_Grid" Cursor="Hand" MouseLeftButtonDown="Chevron_Click" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal" MouseLeftButtonDown="Chevron_Click" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Grid.Column="1" MouseLeftButtonDown="Chevron_Click" x:Name="Username_TextBlock" FontSize="12" Foreground="#4B4b4b" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                            <Border Background="Transparent" MouseLeftButtonDown="Chevron_Click" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <md:PackIcon Grid.Column="1" Name="ChevronDownClick" Kind="ChevronDown" MouseLeftButtonDown="Chevron_Click" Foreground="#4B4b4b" VerticalAlignment="Center" HorizontalAlignment="Right">

                                    <md:PackIcon.ContextMenu>
                                        <ContextMenu Name="ChevronContextMenu" Placement="Bottom">
                                            <MenuItem Header="Logout" Click="BtnLogout_Click" Cursor="Hand"/>
                                            <!--<Separator/>
                                            <MenuItem Header="Hubs" Cursor="Hand"/>-->
                                        </ContextMenu>
                                    </md:PackIcon.ContextMenu>

                                </md:PackIcon>
                            </Border>
                        </StackPanel>
                    </Grid>

                </StackPanel>

            </Grid>

        </Border>


        <Border x:Name="ProjectsBorder" Grid.Row="1" Grid.Column="0" BorderBrush="#797979" BorderThickness="0,0,1,0" Padding="5,0,5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Hubs Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Projects Header -->
                    <RowDefinition Height="*"/>
                    <!-- TreeView -->
                </Grid.RowDefinitions>

                <!-- Hubs Selection Header -->
                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1" Padding="5" Margin="-5,0,-5,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Dynamic Hubs Header -->
                        <TextBlock x:Name="HubsHeaderTextBlock" Text="Hubs - (Loading...)" 
                           FontSize="12" Foreground="#4B4b4b" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>

                        <!-- Dropdown Arrow for Selecting a Hub -->
                        <Border Grid.Column="1" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Right" MouseLeftButtonDown="ToggleHubsMenu">
                            <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#4B4B4B" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Cursor="Hand"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Popup for Hubs Selection -->
                <Popup x:Name="HubsMenuPopup" Placement="Relative" PlacementTarget="{Binding ElementName=HubsHeaderTextBlock}" StaysOpen="False" VerticalOffset="5">
                    <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="5">
                        <StackPanel x:Name="HubsMenuStackPanel"/>
                    </Border>
                </Popup>

                <!-- Projects Header -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left" 
                            MouseEnter="TextBlockBorder_Enter" MouseLeave="TextBlockBorder_Leave" Cursor="Hand" Margin="5,8,0,0">
                        <TextBlock MouseLeftButtonDown="ProjectsText_Click" Text="PROJECTS" FontSize="12" Foreground="#4B4B4B" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Height="16" Width="57"/>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" 
                        HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" 
                        Cursor="Hand" Margin="0,6.5,2,0">
                            <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light"  
                                 Kind="Magnify" Style="{StaticResource IconHover}" Height="15" Width="15"/>
                        </Border>

                        <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" 
                        HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" 
                        Cursor="Hand" Margin="0,6,2,0">
                            <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light" 
                                 Kind="CogOutline" Style="{StaticResource IconHover}" Height="15" Width="15"/>
                        </Border>

                        <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" 
                        HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" 
                        Cursor="Hand" Margin="0,5,2,0">
                            <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light" 
                                 Kind="Plus" Style="{StaticResource IconHover}" Height="16" Width="16"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- TreeView for Projects -->
                <TreeView Grid.Row="2" x:Name="ProjectTreeView" BorderThickness="0" Margin="0,10,0,10"
                  SelectedItemChanged="ProjectTreeView_SelectedItemChanged" 
                  MouseDoubleClick="ProjectTreeView_MouseDoubleClick" 
                  MouseLeftButtonDown="ProjectTreeView_MouseLeftButtonDown">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                            <Setter Property="FontSize" Value="16"/>
                            <!--<Setter Property="FontWeight" Value="Bold"/>-->
                            <Setter Property="Padding" Value="3"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Border>

        <!-- Asset Library -->
        <Border x:Name="LibraryBorder" Grid.Row="1" Grid.Column="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Asset Library" FontSize="20" Foreground="#4B4b4b" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0"/>

                <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" BorderBrush="#4B4B4B" BorderThickness="0,1,0,0" Margin="20,0,20,0"/>

                <Grid Grid.Row="1" RenderTransformOrigin="0.541,0.435">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnUploadFile"
        Template="{StaticResource FirstButtonTemplate}"
        Click=" BtnUploadFile_Click"
        Width="220" Height="80"
        FontFamily="Georgia"
        FontSize="19"
        FontWeight="Bold"
        Foreground="#000000"
        Content="Import Asset"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand" Margin="73,-4,574,-6"/>
                    
                    <Button x:Name="BtnMarketplace"
        Template="{StaticResource MiddleButtonTemplate}"
        Click="BtnMarketplace_Click"
        Width="220" Height="80"
        FontFamily="Georgia"
        FontSize="19"
        FontWeight="Bold"
        Foreground="#000000"
        Content="Marketplace"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand" Margin="255,-3,392,-7"/>

                    <Button x:Name="EmptyButton"
        Template="{StaticResource LastButtonTemplate}"
        Click="BtnMarketplace_Click"
        Width="220" Height="80"
        FontFamily="Georgia"
        FontSize="19"
        FontWeight="Bold"
        Foreground="#000000"
        Content="Enchant"
        Background="Transparent"
        BorderThickness="0"
        Cursor="Hand" Margin="405,-4,242,-6"/>


                    <Button HorizontalAlignment="Left" BorderThickness="0" x:Name="BtnViewDecks" Width="100" Height="40" Click="OpenDeckView_Click" Cursor="Hand" Margin="728,12,0,18">

                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>

                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="#D97C72"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D04C72"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Cards" Width="17" Height="17" VerticalAlignment="Center"/>
                            <TextBlock Text="Decks" Margin="1,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>

                    <!--<Border MouseLeftButtonDown="MarketplaceGrid_Click" BorderBrush="#98730C" BorderThickness="3" CornerRadius="2" Width="90" Height="40" HorizontalAlignment="Left" Margin="130,0,0,0" Cursor="Hand">
                        <Button x:Name="BtnMarketplace" Click="BtnMarketplace_Click" Content="Marketplace" BorderBrush="#98730C" BorderThickness="2" Background="#540754" Foreground="White" Width="90" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                    </Border>-->
                    
                    <!-- <Border MouseLeftButtonDown="UpArrow_Click" x:Name="UpArrowBorder" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0" Visibility="Hidden">
                        <md:PackIcon x:Name="UpArrow" Kind="ArrowUpBoldOutline" Height="30" Width="30" VerticalAlignment="Center" HorizontalAlignment="Center"/> 
