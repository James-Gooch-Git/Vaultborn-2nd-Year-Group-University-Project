    <Window.Resources>

        <Style x:Key="IconHover" TargetType="md:PackIcon">
            <Setter Property="Foreground" Value="#4B4B4B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#F25505"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="TextHoverStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B4B4B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#F25505"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="Thumb">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Cursor" Value="SizeWE"/>
