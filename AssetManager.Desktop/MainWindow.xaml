                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Actions" FontSize="15" TextAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            
                                <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Green" BorderThickness="4" CornerRadius="4">
                                        <Button Click="BtnBuy_Click" Content="Buy" Background="Green" Foreground="Azure" Width="50" Height="20" BorderBrush="Green" BorderThickness="2"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
            
        <!-- Model Info Sidebar -->
        <Border Grid.Row="1" Grid.Column="3" BorderBrush="#797979" BorderThickness="1,0,0,0" Padding="5,0,5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Metadata -->
                    <RowDefinition Height="Auto"/> <!-- Tags -->
                    <RowDefinition Height="Auto"/> <!-- Visibility -->
                    <RowDefinition Height="Auto"/> <!-- Upvotes -->
                    <RowDefinition Height="Auto"/> <!-- List Model -->
                    <RowDefinition Height="Auto"/> <!-- Comments Header -->
                    <RowDefinition Height="Auto"/> <!-- Post Comments -->
                    <RowDefinition Height="Auto"/> <!-- Sort Comments -->
                    <RowDefinition Height="*"/> <!-- Comments List -->
                </Grid.RowDefinitions>
                
                <TextBlock Text="Model Info"/>
                
                <ComboBox Grid.Row="2" x:Name="PublicPrivateComboBox" SelectionChanged="PublicPrivateComboBox_OnSelectionChangedComboBox_SelectionChanged" Width="100" Height="30" Margin="0,0,0,0">
                    <ComboBoxItem x:Name="Public">Public</ComboBoxItem>
                    <ComboBoxItem x:Name="Private">Private</ComboBoxItem>
                </ComboBox>
                
                <Border Grid.Row="3" MouseLeftButtonDown="UpArrow_Click" x:Name="UpArrowBorder" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                    <md:PackIcon x:Name="UpArrow" Kind="ArrowUpBoldOutline" Height="30" Width="30" VerticalAlignment="Center" HorizontalAlignment="Center"/> <!-- Foreground="#11d137" -->
                </Border>

                <TextBlock Grid.Row="3" x:Name="UpvoteTextBlock" Text="0" Height="30" Width="30" FontSize="20" FontFamily="Arial" Margin="50,10,0,0" TextAlignment="Center"/>

                <Border Grid.Row="3" MouseLeftButtonDown="DownArrow_Click" x:Name="DownArrowBorder" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="100,0,5,0">
                    <md:PackIcon x:Name="DownArrow" Kind="ArrowDownBoldOutline" Height="30" Width="30" VerticalAlignment="Center" HorizontalAlignment="Center"/> <!-- Foreground="Red" -->
                </Border>
                
                <Button x:Name="BtnListModel"  Content="List Model"  Width="75" Height="30" Click="BtnListModel_Click" Grid.Row="4" />
                
                <Popup x:Name="ListModelPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnListModel}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-150">
                        <Border x:Name="ListModelBorder" Background="#5c1c1c" CornerRadius="5"
                                Width="200" Height="200">
                            <!-- <Border.Effect>
                                <DropShadowEffect BlurRadius="50" ShadowDepth="10" Color="Black" Opacity="0.2"/>
                            </Border.Effect> -->
                            <Grid Margin="10,10,10,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/> <!-- Price -->
                                    <RowDefinition Height="5"/> <!-- Space -->
                                    <RowDefinition Height="*"/> <!-- Description -->
                                    <RowDefinition Height="30"/> <!-- List -->
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="Price:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox x:Name="PriceTextBox" Text="Enter Price" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="50"/>
                                
                                <TextBlock Grid.Row="2" Text="Description:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox Grid.Row="2" x:Name="DescriptionTextBox" Text="Enter Description" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="100"/>
                                
                                <Border Grid.Row="3" BorderBrush="#98730C" BorderThickness="2" CornerRadius="3" Width="60" Height="20" HorizontalAlignment="Center">
                                    <Button Content="List" Click="BtnList_Click" Background="#540754" Foreground="White"
                                            Width="60" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>
                
                <!-- Display Tags -->
                <WrapPanel Grid.Row="1" x:Name="TagsWrapPanel">
                    <TextBlock x:Name="NoTagsText" Text="No Tags Currently selected"/>
                    <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" 
                            HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" 
                            Cursor="Hand" MouseLeftButtonDown="AddTags_Click">
                        <md:PackIcon Cursor="Hand" HorizontalAlignment="Right" FontWeight="Light" 
                                     Kind="Plus" Style="{StaticResource IconHover}" Height="16" Width="16"/>
                    </Border>
                </WrapPanel>
                <!-- <ListBox x:Name="DisplayTagsListBox" Grid.Row="6" Width="200" Height="200" HorizontalAlignment="Right" Visibility="Hidden" ItemsSource="{Binding Tags}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Label Content="{Binding }"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox> -->
                
                <!-- Comments Header -->
                <TextBlock Grid.Row="5" x:Name="CommentsAmount" Text="All Comments (0)"/>
                
                <!-- Comments List -->
                <ListBox x:Name="ListComments" Width="Auto" Height="Auto" 
                         Grid.Row="8" HorizontalAlignment="Center">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                </Grid.ColumnDefinitions>
                                <Label Content="{Binding User}" />
                                <Label Grid.Column="1" Content="{Binding Content}" />
                                <Label Grid.Column="2" Content="{Binding CreatedDateTime}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Comment Input -->
                <TextBox x:Name="CommentContent" Text="Add a comment"
                         Width="75" Height="30" Grid.Row="6" HorizontalAlignment="Left"/>

                <!-- Post Comment Button -->
                <Button x:Name="BtnAddComment"  
                        Content="Post Comment"  
                        Width="75" Height="30" 
                        Click="BtnAddComment_Click" 
                        Grid.Row="6" HorizontalAlignment="Right"/>

                <!-- Sort By for Comments -->
                <ComboBox Grid.Row="7" Name="SortByComboBox" SelectionChanged="SortByComboBox_SelectionChanged" Width="150" Height="30">
                    <ComboBoxItem>Newest</ComboBoxItem>
                    <ComboBoxItem>Oldest</ComboBoxItem>
                </ComboBox>
                
            </Grid>
        </Border>

    </Grid>

</Window>
