                    <Slider Name="slider"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Width="1030"
            Minimum="0"
            Maximum="100"
            TickPlacement="BottomRight"
            IsSnapToTickEnabled="True"
            Value="100"
            Margin="0,0,0,35">
                        <Slider.Resources>
                            <Style TargetType="Slider">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <!-- Full Track Background -->
                                                <Rectangle Height="6"
                                           Fill="LightGray"
                                           VerticalAlignment="Center"
                                           Width="1030" 
                                                    RadiusX="3" RadiusY="3"/>

                                                    <!-- Track -->
                                                    <Track x:Name="PART_Track">
                                                        <Track.Thumb>
                                                            <Thumb Width="30" Height="30" BorderThickness="0">
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Grid>
                                                                            <!-- Teardrop Shape -->
                                                                            <Path Fill="Blue" 
                                                              Stretch="Uniform"
                                                              Data="M 10,0 
                                                                    C 20,0, 20,10, 10,20
                                                                    C 0,10, 0,0, 10,0 
                                                                    Z" />
                                                                        </Grid>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>

                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Width="0" Background="Transparent"/>
                                                        </Track.IncreaseRepeatButton>

                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Width="0" Background="Transparent"/>
                                                        </Track.DecreaseRepeatButton>
                                                    </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
