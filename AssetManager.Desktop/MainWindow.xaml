<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Desktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="100" Width="100">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- Upload File Button -->
            <Button x:Name="BtnUploadFile" 
                    Content="Upload File" 
                    Width="200" Height="40" 
                    Click="BtnUploadFile_Click"/>
            
            <!-- <Button Content="Download Model" Click="DownloadModelButton_Click" Width="150" Height="40"/> -->

        </StackPanel>
    </Grid>
</Window>
