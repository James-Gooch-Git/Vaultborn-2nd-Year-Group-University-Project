                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Upvotes</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Price Lowest</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Price Highest</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Name Z-A</ListBoxItem>
                                </ListBox>
                            </Border>
                        </Popup>

                        <Rectangle Fill="#A3A3A3" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Border MouseLeftButtonDown="Filter_Click" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon Kind="FilterOutline" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Rectangle Fill="#A3A3A3" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Border  x:Name="MarketplaceGridBorder" MouseLeftButtonDown="MarketplaceGrid_Click" Background="Transparent" BorderBrush="Transparent" CornerRadius="3" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon  MouseLeftButtonDown="MarketplaceGrid_Click" Kind="ViewGridOutline" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Border x:Name="MarketplaceListBorder" MouseLeftButtonDown="MarketplaceList_Click" Background="#E9E9E9" BorderBrush="Transparent" CornerRadius="3" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon MouseLeftButtonDown="MarketplaceList_Click" Grid.Row="1" Grid.Column="1" Kind="FormatListBulleted" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Rectangle Fill="#A3A3A3" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,8,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Button Cursor="IBeam" Focusable="False"  Width="130" Height="24" Background="Transparent" BorderBrush="#4B4B4B" Margin="0,0,20,0">

                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>

                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" Foreground="#4B4B4B" Margin="0,0,0,0"/>
                                <TextBox x:Name="MarketplaceSearchTextBox" VerticalAlignment="Center" VerticalContentAlignment="Center" Width="89" FontSize="10" Height="19" Margin="3,0,0,0" KeyDown="MarketplaceSearch_OnKeyDown"/>
                                <!-- <TextBlock Text="Search By Name..." Foreground="#A3A3A3" FontSize="10" Margin="3,0,0,0" VerticalAlignment="Center"/> -->
                                <md:PackIcon Kind="Close" Cursor="Hand" MouseLeftButtonDown="MarketplaceClearSearch_Click" Width="14" Height="14" VerticalAlignment="Center" Foreground="#4B4B4B" Margin="3,0,0,0"/>
                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Grid>

                <Grid Grid.Row="2" x:Name="MarketplaceGridView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="MarketplaceModelsContainer" HorizontalAlignment="Center" VerticalAlignment="Top" />
                    </ScrollViewer>
                </Grid>

                <DataGrid Grid.Row="2" x:Name="MarketplaceDataGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Background="Transparent" 
                                  Margin="20,0,20,0" 
                                  BorderThickness="0" 
                                  HorizontalAlignment="Center" 
                                  SelectionChanged="ModelsDataGrid_SelectionChanged" 
                                  GridLinesVisibility="None" 
                                  RowBackground="Transparent" 
                                  AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" 
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                  Visibility="Visible">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,0,5,0"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="Margin" Value="0,10,0,5"/>
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontSize="16" TextBlock.FontWeight="Bold"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Name" Binding="{Binding [Name]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#4B4B4B"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#4B4B4B"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Description" Binding="{Binding [Description]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#4B4B4B"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#4B4B4B"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Price" Binding="{Binding [Price], StringFormat='£'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#4B4B4B"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#4B4B4B"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Seller" Binding="{Binding [Seller]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#4B4B4B"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#4B4B4B"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Id" Binding="{Binding [Id]}" Width="*" Visibility="Collapsed"/>

                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#4B4B4B"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#4B4B4B"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Actions" FontSize="15" TextAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border BorderBrush="Green" BorderThickness="4" CornerRadius="4" Visibility="{Binding [BuyVisibility], Converter={StaticResource StringToVisibilityConverter}}">
                                            <Button Click="BtnBuy_Click" Content="Buy" Background="Green" Foreground="Azure" Width="50" Height="20" BorderBrush="Green" BorderThickness="2"/>
                                        </Border>
                                        <TextBlock Text="Purchased" FontWeight="Normal" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding [PurchasedVisibility], Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Popup x:Name="BuyPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnLibrary}" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="150">
                    <Border x:Name="BuyBorder" Background="#5c1c1c" CornerRadius="5"
                            Width="400" Height="400">

                        <wv2:WebView2  Name="webView" Source="about:blank" Height="390" Width="390" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <!-- Model Info Sidebar -->
        <Border Grid.Row="1" Grid.Column="3" BorderBrush="#797979" BorderThickness="1,0,0,0" Padding="5,0,5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <StackPanel Grid.Row="0" Orientation="Vertical">

                    <Button x:Name="CloseSidebarButton" Click="CloseSidebar_Click" Background="Transparent" BorderThickness="0" Width="10" Height="10" Margin="0,5,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" BorderBrush="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>


                        <md:PackIcon Kind="Close" Width="10" Height="10" Foreground="#4B4B4B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Model Thumbnail and Name -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Margin="2,2,2,2">

                        <!-- Background Border Behind Image -->
                        <Border Background="#E6E6E6" HorizontalAlignment="Stretch" Padding="10" CornerRadius="5">
                            <Grid>
                                <Image x:Name="ModelImage" Width="120" Height="120" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Model Name -->
                        <TextBlock x:Name="ModelNameText" Text="Model Name" Foreground="#4B4b4b" FontSize="18" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,5"/>

                    </StackPanel>

                </StackPanel>

                <StackPanel x:Name="ModelInfo" Grid.Row="1" Orientation="Vertical" Visibility="Collapsed" Margin="5,5,5,10">

                    <!-- Metadata Info -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,5">

                        <!--<StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Id: " FontWeight="Bold"/>
                            <TextBlock x:Name="IdText"/>
                        </StackPanel>-->

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Model Version: " FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>

                            <Button x:Name="ModelVersionButton" Foreground="Black" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0" Click="ModelVersionButton_Click" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" BorderBrush="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ModelVersionText" Text="" VerticalAlignment="Center"/>
                                    <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#4B4B4B" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>


                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Created By: " FontWeight="Bold"/>
                            <TextBlock x:Name="CreatedByText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Date Created: " FontWeight="Bold"/>
                            <TextBlock x:Name="CreatedDateText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Last Modified: " FontWeight="Bold"/>
                            <TextBlock x:Name="ModifiedDateText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Modified By: " FontWeight="Bold"/>
                            <TextBlock x:Name="ModifiedByText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Project: " FontWeight="Bold"/>
                            <TextBlock x:Name="FolderNameText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="File Size: " FontWeight="Bold"/>
                            <TextBlock x:Name="FileSizeText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="File Format: " FontWeight="Bold"/>
                            <TextBlock x:Name="FormatText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Dimensions: " FontWeight="Bold"/>
                            <TextBlock x:Name="DimensionsText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Poly Count: " FontWeight="Bold"/>
                            <TextBlock x:Name="PolyCountText"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Public/Private:" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>

                            <!-- Public/Private Selection as a Button -->
                            <Button x:Name="PublicPrivateButton" Foreground="Black" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0" Click="PublicPrivateButton_Click" VerticalAlignment="Center">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" BorderBrush="Transparent" >
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="PublicPrivateText" Text="Private" VerticalAlignment="Center"/>
                                    <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#4B4B4B" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Attach ContextMenu -->
                                <Button.Resources>
                                    <ContextMenu x:Key="PublicPrivateMenu">
                                        <MenuItem Header="Public" Click="SetPublic_Click"/>
                                        <MenuItem Header="Private" Click="SetPrivate_Click"/>
                                    </ContextMenu>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                    </StackPanel>

                    <!-- Display Tags -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- "Tags:" Label -->
                        <TextBlock Text="Tags:" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>

                        <!-- Container for Tags (Buttons) & Plus Icon -->
                        <WrapPanel x:Name="TagsWrapPanel" VerticalAlignment="Center">

                            <!-- Placeholder when no tags are selected -->
                            <TextBlock x:Name="NoTagsText" Text="No Tags Currently selected" VerticalAlignment="Center" Visibility="Collapsed"/>

                        </WrapPanel>

                        <!-- Plus Icon for Adding Tags -->
                        <Border Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" MouseLeftButtonDown="AddTags_Click" Margin="5,0,0,0">
                            <md:PackIcon Cursor="Hand" VerticalAlignment="Center" FontWeight="Light" Kind="Plus" Style="{StaticResource IconHover}" Height="16" Width="16"/>
                        </Border>

                    </StackPanel>



                    <!-- List Model Button & Popup -->
                    <Border x:Name="ListModelButtonBorder" MouseLeftButtonDown="MarketplaceGrid_Click" BorderBrush="#98730C" BorderThickness="3" CornerRadius="2" Width="90" Height="40" HorizontalAlignment="Center" Margin="0,20,0,0" Cursor="Hand">
                        <Button  x:Name="BtnListModel" Content="List Model" Click="BtnListModel_Click" Grid.Row="4" BorderBrush="#98730C" BorderThickness="2" Background="#540754" Foreground="White" Width="90" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                    </Border>

                    <Popup x:Name="ListModelPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnListModel}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-150">
                        <Border x:Name="ListModelBorder" Background="#5c1c1c" CornerRadius="5" Width="200" Height="200">
                            <Grid Margin="10,10,10,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/> <!-- Price -->
                                    <RowDefinition Height="5"/> <!-- Space -->
                                    <RowDefinition Height="*"/> <!-- Description -->
                                    <RowDefinition Height="30"/> <!-- List -->
                                </Grid.RowDefinitions>

                                <TextBlock Text="Price:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox x:Name="PriceTextBox" Text="Enter Price" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="50"/>

                                <TextBlock Grid.Row="2" Text="Description:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox Grid.Row="2" x:Name="DescriptionTextBox" Text="Enter Description" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="100"/>

                                <Border Grid.Row="3" BorderBrush="#98730C" BorderThickness="2" CornerRadius="3" Width="60" Height="20" HorizontalAlignment="Center">
                                    <Button Content="List" Click="BtnList_Click" Background="#540754" Foreground="White" Width="60" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>

                </StackPanel>

                <StackPanel x:Name="ModelComments" Grid.Row="1" Orientation="Vertical" Visibility="Collapsed">

                    <!-- Upvotes Section -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

                        <Border MouseLeftButtonDown="UpArrow_Click" x:Name="UpArrowBorder" Background="Transparent" Cursor="Hand">
                            <md:PackIcon x:Name="UpArrow" Foreground="#4B4b4b" Kind="ArrowUpBoldOutline" Height="25" Width="25"/>
                        </Border>

                        <TextBlock x:Name="UpvoteTextBlock" Text="0" Foreground="#4B4b4b" FontSize="16" FontWeight="Bold" Margin="10,0,10,0" VerticalAlignment="Center"/>

                        <Border MouseLeftButtonDown="DownArrow_Click" x:Name="DownArrowBorder" Background="Transparent" Cursor="Hand">
                            <md:PackIcon x:Name="DownArrow" Foreground="#4B4b4b" Kind="ArrowDownBoldOutline" Height="25" Width="25"/>
                        </Border>

                    </StackPanel>

                    <!-- Comments Header -->
                    <TextBlock Text="All Comments (0)" x:Name="CommentsAmount" Foreground="#4B4b4b" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Add Comment Section -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10" Width="Auto">

                        <!-- User Profile Image -->
                        <Ellipse Width="30" Height="30" Fill="Gray" Margin="0,0,10,0"/>

                        <!-- Comment Input Field with Send Icon -->
                        <Grid Width="Auto">
                            <Border Background="White" Padding="2" BorderThickness="1" BorderBrush="#4B4b4b" Width="185" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Set a fixed height -->
                                <Grid>
                                    <!-- Text Input -->
                                    <TextBox x:Name="CommentContent" BorderThickness="0" VerticalContentAlignment="Center" VerticalAlignment="Center" Background="Transparent" Padding="5,0,35,0" Height="24">
                                        <!--<TextBox.Style>
                                            <Style TargetType="TextBox">
                                                ~1~<Setter Property="Foreground" Value="Gray"/>
                                                <Setter Property="Text" Value="Add a comment..."/>@1@
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="Text" Value=""/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </Trigger>
                                                    ~1~<Trigger Property="IsKeyboardFocused" Value="False">
                                                        <Setter Property="Foreground" Value="Gray"/>
                                                        <Setter Property="Text" Value="Add a comment..."/>
                                                    </Trigger>@1@
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>-->
                                    </TextBox>
                                    <!-- Reduced height -->

                                    <!-- Send Button (PackIcon inside input field) -->
                                    <Button x:Name="BtnAddComment" Click="BtnAddComment_Click" Width="24" Height="24" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <md:PackIcon Kind="Send" Width="18" Height="18" Foreground="#4B4B4B"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                    </StackPanel>

                    <Border HorizontalAlignment="Stretch" VerticalAlignment="Center" BorderBrush="#4B4B4B" BorderThickness="0,1,0,0" Margin="3,5,3,10"/>

                    <!-- Sort Comments -->
                    <!--<ComboBox x:Name="SortByComboBox" SelectionChanged="SortByComboBox_SelectionChanged" Width="150" Height="30" Margin="0,0,0,10">
                    <ComboBoxItem Content="Newest"/>
                    <ComboBoxItem Content="Oldest"/>
                </ComboBox>-->

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">

                        <!-- "Sort By" Text -->
                        <TextBlock Text="Sort By" FontSize="14" Foreground="Black" VerticalAlignment="Center"/>

                        <!-- Sort Button with Dropdown -->
                        <Button x:Name="SortByButton" FontSize="14" Foreground="Black" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5,2,5,2" Click="SortByButton_Click" VerticalAlignment="Center">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" BorderBrush="Transparent" Padding="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="SortByText" Text="Newest" FontSize="14" VerticalAlignment="Center"/>
                                <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#4B4B4B" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Attach ContextMenu Properly Inside Resources -->
                            <Button.Resources>
                                <ContextMenu x:Key="SortMenu">
                                    <MenuItem Header="Newest" Click="SortByNewest_Click"/>
                                    <MenuItem Header="Oldest" Click="SortByOldest_Click"/>
                                </ContextMenu>
                            </Button.Resources>
                        </Button>

                    </StackPanel>

                    <!-- Comments List -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" Background="Transparent" BorderThickness="0" Height="Auto" Width="225" HorizontalAlignment="Left">

                        <ListBox x:Name="ListComments" Background="Transparent" BorderThickness="0" Padding="0" Margin="0" VerticalAlignment="Stretch" HorizontalAlignment="Left">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                                        <!-- User Avatar -->
                                        <Ellipse Width="40" Height="40" Fill="Gray" Margin="0,0,10,0"/>

                                        <!-- Comment Content -->
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding User}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Width="140"/>
                                            <TextBlock Text="{Binding CreatedDateTime}" FontSize="10" Foreground="Gray"/>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding Version}" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>
