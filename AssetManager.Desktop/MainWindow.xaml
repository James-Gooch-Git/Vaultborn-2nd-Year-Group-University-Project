                        </Button.Resources>
                    </Button>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <Border Cursor="Hand" MouseLeftButtonDown="MarketplaceSort_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SortByTextBlock" Text="Sort By Name A-Z" Cursor="Hand" FontSize="13" Foreground="#d1d5db" VerticalAlignment="Center"/>
                                <md:PackIcon x:Name="SortChevron" Kind="ChevronDown" Cursor="Hand" Foreground="#d1d5db" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </StackPanel>
                        </Border>

                        <Popup x:Name="SortPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=SortChevron}" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-105" Closed="SortPopup_Closed">
                            <Border x:Name="SortBorder" Background="#540754" CornerRadius="5"
                                    Width="120" Height="130">

                                <ListBox x:Name="SortListBox" SelectionChanged="SortListBox_SelectionChanged" Margin="10" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Name A-Z</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Upvotes</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Price Lowest</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Price Highest</ListBoxItem>
                                    <ListBoxItem Height="20" Foreground="White" VerticalAlignment="Center" BorderBrush="#98730c" BorderThickness="0,0,0,1">Name Z-A</ListBoxItem>
                                </ListBox>
                            </Border>
                        </Popup>

                        <Rectangle Fill="#d1d5db" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Border MouseLeftButtonDown="Filter_Click" Background="Transparent" BorderBrush="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="Border_Enter" MouseLeave="Border_Leave" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon Kind="FilterOutline" Foreground="#d1d5db" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Rectangle Fill="#d1d5db" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Border  x:Name="MarketplaceGridBorder" MouseLeftButtonDown="MarketplaceGrid_Click" Background="Transparent" BorderBrush="Transparent" CornerRadius="3" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon x:Name="MarketplaceGridIcon" MouseLeftButtonDown="MarketplaceGrid_Click" Foreground="#d1d5db" Kind="ViewGridOutline" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Border x:Name="MarketplaceListBorder" MouseLeftButtonDown="MarketplaceList_Click" Background="Transparent" BorderBrush="Transparent" CornerRadius="3" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,5,0">
                            <md:PackIcon x:Name="MarketplaceListIcon" MouseLeftButtonDown="MarketplaceList_Click" Foreground="#d1d5db" Kind="FormatListBulleted" Cursor="Hand" Style="{StaticResource IconHover}" VerticalAlignment="Center"/>
                        </Border>

                        <Rectangle Fill="#d1d5db" Height="20" Width="1" RenderTransformOrigin="0.5,0.5" Margin="0,0,8,0">
                            <Rectangle.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Button Cursor="IBeam" Focusable="False"  Width="130" Height="24" Background="Transparent" BorderBrush="#d1d5db" Margin="0,0,20,0">

                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>

                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" Foreground="#d1d5db" Margin="0,0,0,0"/>
                                <TextBox x:Name="MarketplaceSearchTextBox" VerticalAlignment="Center" VerticalContentAlignment="Center" Width="89" FontSize="10" Height="19" Margin="3,0,0,0" KeyDown="MarketplaceSearch_OnKeyDown"/>
                                <!-- <TextBlock Text="Search By Name..." Foreground="#A3A3A3" FontSize="10" Margin="3,0,0,0" VerticalAlignment="Center"/> -->
                                <md:PackIcon Kind="Close" Cursor="Hand" MouseLeftButtonDown="MarketplaceClearSearch_Click" Width="14" Height="14" VerticalAlignment="Center" Foreground="#d1d5db" Margin="3,0,0,0"/>
                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Grid>

                <Grid Grid.Row="2" x:Name="MarketplaceGridView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="MarketplaceModelsContainer" HorizontalAlignment="Center" VerticalAlignment="Top" />
                    </ScrollViewer>
                </Grid>

                <DataGrid Grid.Row="2" x:Name="MarketplaceDataGrid" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  Background="Transparent" 
                                  Margin="20,0,20,0" 
                                  BorderThickness="0" 
                                  HorizontalAlignment="Center" 
                                  SelectionChanged="ModelsDataGrid_SelectionChanged" 
                                  GridLinesVisibility="None" 
                                  RowBackground="Transparent" 
                                  AlternatingRowBackground="Transparent" 
                                  HeadersVisibility="Column" 
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                  Visibility="Visible">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5,0,5,0"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="Margin" Value="0,10,0,5"/>
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.FontSize="16" TextBlock.FontWeight="Bold"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Name" Binding="{Binding [Name]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#98730c"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Description" Binding="{Binding [Description]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#98730c"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Price" Binding="{Binding [Price], StringFormat='£'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#98730c"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Seller" Binding="{Binding [Seller]}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#98730c"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>

                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Margin" Value="0,5,0,5" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Id" Binding="{Binding [Id]}" Width="*" Visibility="Collapsed"/>

                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#98730c"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="16"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Setter Property="Margin" Value="0,10,0,5"/>
                                    <Setter Property="Padding" Value="0,0,0,10"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>

                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Actions" FontSize="15" TextAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border BorderBrush="Green" BorderThickness="4" CornerRadius="4" Visibility="{Binding [BuyVisibility], Converter={StaticResource StringToVisibilityConverter}}">
                                            <Button Click="BtnBuy_Click" Content="Buy" Background="Green" Foreground="#d1d5db" Width="50" Height="20" BorderBrush="Green" BorderThickness="2"/>
                                        </Border>
                                        <TextBlock Text="Purchased" Foreground="#d1d5db" FontWeight="Normal" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding [PurchasedVisibility], Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Popup x:Name="BuyPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=ModelsButton}" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="150">
                    <Border x:Name="BuyBorder" Background="#540754" CornerRadius="5"
                            Width="400" Height="400">

                        <wv2:WebView2  Name="webView" Source="about:blank" Height="390" Width="390" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <!-- right thumb -->
        <!--<Thumb Grid.Row="1" Grid.Column="3" Width="5" Cursor="SizeWE" DragDelta="ResizeModelSidebar_DragDelta" Background="#98730c"/>-->
        <Thumb Grid.Row="1" Grid.Column="3" Width="5" Cursor="SizeWE" DragDelta="ResizeModelSidebar_DragDelta" Margin="0,0,0,0" Canvas.ZIndex="999">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" Width="15"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Model Info Sidebar -->
        <Border Grid.Row="1" Grid.Column="4" BorderBrush="#98730c" BorderThickness="1,0,0,0" Padding="5,0,5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <StackPanel Grid.Row="0" Orientation="Vertical">

                    <Button x:Name="CloseSidebarButton" Click="CloseSidebar_Click" Background="Transparent" BorderThickness="0" Width="10" Height="10" Margin="0,5,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" BorderBrush="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>


                        <md:PackIcon Kind="Close" Width="10" Height="10" Foreground="#d1d5db" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Model Thumbnail and Name -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Margin="2,2,2,2">

                        <!-- Background Border Behind Image -->
                        <Border Background="#4B0082" HorizontalAlignment="Stretch" Padding="10" CornerRadius="5">
                            <Grid>
                                <Image x:Name="ModelImage" Width="120" Height="120" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Model Name -->
                        <TextBlock x:Name="ModelNameText" Text="Model Name" Foreground="#d1d5db" FontSize="18" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,5"/>

                    </StackPanel>

                </StackPanel>

                <StackPanel x:Name="ModelInfo" Grid.Row="1" Orientation="Vertical" Visibility="Collapsed" Margin="5,5,5,10">

                    <!-- Metadata Info -->
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto" Height="260" >
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        
                        <StackPanel Orientation="Vertical" Margin="0,0,0,5">

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Model Version: " FontWeight="Bold" Foreground="#d1d5db" VerticalAlignment="Center"/>

                            <Button x:Name="ModelVersionButton" Foreground="#d1d5db" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0" Click="ModelVersionButton_Click" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" BorderBrush="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#d1d5db"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ModelVersionText" Text="" VerticalAlignment="Center"/>
                                    <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#d1d5db" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Created By: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="CreatedByText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Date Created: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="CreatedDateText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Last Modified: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="ModifiedDateText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Modified By: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="ModifiedByText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <!--<StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Project: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="FolderNameText" Foreground="#d1d5db"/>
                        </StackPanel>-->

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="File Size: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="FileSizeText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="File Format: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="FormatText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Dimensions: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="DimensionsText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Poly Count: " FontWeight="Bold" Foreground="#d1d5db"/>
                            <TextBlock x:Name="PolyCountText" Foreground="#d1d5db"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Public/Private:" FontWeight="Bold" Foreground="#d1d5db" VerticalAlignment="Center"/>

                            <!-- Public/Private Selection as a Button -->
                            <Button x:Name="PublicPrivateButton" Foreground="#d1d5db" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0,0,0" Click="PublicPrivateButton_Click" VerticalAlignment="Center">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" BorderBrush="Transparent" >
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#d1d5db"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="PublicPrivateText" Text="Private" VerticalAlignment="Center"/>
                                    <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#d1d5db" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Attach ContextMenu -->
                                <Button.Resources>
                                    <ContextMenu x:Key="PublicPrivateMenu">
                                        <MenuItem Header="Public" Click="SetPublic_Click"/>
                                        <MenuItem Header="Private" Click="SetPrivate_Click"/>
                                    </ContextMenu>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                    </ScrollViewer>

                    <TextBlock Text="Tags:" FontWeight="Bold" Foreground="#d1d5db" Margin="0,0,0,5"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">

                            <!-- Container for Tags with ScrollViewer -->
                            <DockPanel LastChildFill="False" HorizontalAlignment="Left">

                                <!-- Scrollable WrapPanel for Tags -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="300" MinHeight="50" MinWidth="100" Width="Auto">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollBarStyle}" />
                                    </ScrollViewer.Resources>

                                    <WrapPanel x:Name="TagsWrapPanel" VerticalAlignment="Center" Margin="5,0,0,0">
                                        <TextBlock x:Name="NoTagsText" Text="No Tags Currently selected" VerticalAlignment="Center" Foreground="#d1d5db" FontStyle="Italic" Visibility="Collapsed" Margin="3" />
                                    </WrapPanel>

                                </ScrollViewer>

                            </DockPanel>
                        </Grid>

                        <Grid Grid.Column="1">
                            <!-- Plus Icon for Adding Tags -->
                            <Border Background="#540754" BorderBrush="#98730C" BorderThickness="2" CornerRadius="2" Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,2,0,0" Cursor="Hand" MouseLeftButtonDown="AddTags_Click">
                                <md:PackIcon Kind="Plus" Style="{x:Null}" Height="16" Width="16" Foreground="#d1d5db" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- List Model Button & Popup -->
                    <Border x:Name="ListModelButtonBorder" BorderBrush="#98730C" BorderThickness="3" CornerRadius="2" Width="90" Height="40" HorizontalAlignment="Center" Margin="0,20,0,0" Cursor="Hand">
                        <Button  x:Name="BtnListModel" Content="List Model" Click="BtnListModel_Click" Grid.Row="4" BorderBrush="#98730C" BorderThickness="2" Background="#540754" Foreground="White" Width="90" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                    </Border>

                    <Popup x:Name="ListModelPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=BtnListModel}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-150">
                        <Border x:Name="ListModelBorder" Background="#540754" CornerRadius="5" Width="200" Height="200">
                            <Grid Margin="10,10,10,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <!-- Price -->
                                    <RowDefinition Height="5"/>
                                    <!-- Space -->
                                    <RowDefinition Height="*"/>
                                    <!-- Description -->
                                    <RowDefinition Height="30"/>
                                    <!-- List -->
                                </Grid.RowDefinitions>

                                <TextBlock Text="Price:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox x:Name="PriceTextBox" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="50"/>

                                <TextBlock Grid.Row="2" Text="Description:" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBox Grid.Row="2" x:Name="DescriptionTextBox" Background="Transparent" Foreground="White" BorderBrush="#98730c" HorizontalAlignment="Right" MinWidth="100"/>

                                <Border Grid.Row="3" BorderBrush="#98730C" BorderThickness="2" CornerRadius="3" Width="60" Height="20" HorizontalAlignment="Center">
                                    <Button Content="List" Click="BtnList_Click" Background="#540754" Foreground="White" Width="60" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>

                </StackPanel>

                <StackPanel x:Name="ModelComments" Grid.Row="1" Orientation="Vertical" Visibility="Collapsed">

                    <!-- Upvotes Section -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">

                        <Border MouseLeftButtonDown="UpArrow_Click" x:Name="UpArrowBorder" Background="Transparent" Cursor="Hand" MouseEnter="Border_Enter" MouseLeave="Border_Leave">
                            <md:PackIcon x:Name="UpArrow" Foreground="#d1d5db" Kind="ArrowUpBoldOutline" Height="25" Width="25"/>
                        </Border>

                        <TextBlock x:Name="UpvoteTextBlock" Text="0" Foreground="#d1d5db" FontSize="16" FontWeight="Bold" Margin="10,0,10,0" VerticalAlignment="Center"/>

                        <Border MouseLeftButtonDown="DownArrow_Click" x:Name="DownArrowBorder" Background="Transparent" Cursor="Hand" MouseEnter="Border_Enter" MouseLeave="Border_Leave">
                            <md:PackIcon x:Name="DownArrow" Foreground="#d1d5db" Kind="ArrowDownBoldOutline" Height="25" Width="25"/>
                        </Border>

                    </StackPanel>

                    <!-- Comments Header -->
                    <TextBlock Text="All Comments (0)" x:Name="CommentsAmount" Foreground="#d1d5db" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Add Comment Section -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10" Width="Auto">

                        <!-- User Profile Image -->
                        <!--<Ellipse Width="30" Height="30" Fill="Gray" Margin="0,0,10,0"/>-->
                        <Image x:Name="UserComment_Image" Width="30" Height="30" Margin="0,0,10,0" ClipToBounds="True" Stretch="UniformToFill"/>


                        <!-- Comment Input Field with Send Icon -->
                        <Grid Width="Auto">
                            <Border Background="Transparent" Padding="2" BorderThickness="1" BorderBrush="#d1d5db" Width="185" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Set a fixed height -->
                                <Grid>
                                    <!-- Text Input -->
                                    <TextBox x:Name="CommentContent" BorderThickness="0" VerticalContentAlignment="Center" CaretBrush="#d1d5db" VerticalAlignment="Center" Background="Transparent" Foreground="#d1d5db" Padding="5,0,35,0" Height="24">
                                        
                                    </TextBox>
                                    <!-- Reduced height -->

                                    <!-- Send Button (PackIcon inside input field) -->
                                    <Button x:Name="BtnAddComment" Click="BtnAddComment_Click" Width="24" Height="24" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <md:PackIcon Kind="Send" Width="18" Height="18" Foreground="#d1d5db"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                    </StackPanel>

                    <Border HorizontalAlignment="Stretch" VerticalAlignment="Center" BorderBrush="#4B4B4B" BorderThickness="0,1,0,0" Margin="3,5,3,10"/>

                    <!-- Sort Comments -->
                    <!--<ComboBox x:Name="SortByComboBox" SelectionChanged="SortByComboBox_SelectionChanged" Width="150" Height="30" Margin="0,0,0,10">
                    <ComboBoxItem Content="Newest"/>
                    <ComboBoxItem Content="Oldest"/>
                </ComboBox>-->

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">

                        <!-- "Sort By" Text -->
                        <TextBlock Text="Sort By" FontSize="14" Foreground="#d1d5db" VerticalAlignment="Center"/>

                        <!-- Sort Button with Dropdown -->
                        <Button x:Name="SortByButton" FontSize="14" Foreground="#d1d5db" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5,2,5,2" Click="SortByButton_Click" VerticalAlignment="Center">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" BorderBrush="Transparent" Padding="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#d1d5db"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="SortByText" Text="Newest" FontSize="14" VerticalAlignment="Center"/>
                                <md:PackIcon Kind="ChevronDown" Width="16" Height="16" Foreground="#d1d5db" Margin="2,-1,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Attach ContextMenu Properly Inside Resources -->
                            <Button.Resources>
                                <ContextMenu x:Key="SortMenu">
                                    <MenuItem Header="Newest" Click="SortByNewest_Click"/>
                                    <MenuItem Header="Oldest" Click="SortByOldest_Click"/>
                                </ContextMenu>
                            </Button.Resources>
                        </Button>

                    </StackPanel>

                    <!-- Comments List -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" Background="Transparent" BorderThickness="0" Height="Auto" Width="225" HorizontalAlignment="Left">

                        <ListBox x:Name="ListComments" Background="Transparent" BorderThickness="0" Padding="0" Margin="0" VerticalAlignment="Stretch" HorizontalAlignment="Left">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                                        <!-- User Avatar -->
                                        <!--<Ellipse Width="40" Height="40" Fill="Gray" Margin="0,0,10,0"/>-->

                                        <Image Width="40" Height="40" Margin="0,0,10,0" ClipToBounds="True" Stretch="UniformToFill">
                                            <Image.Source>
                                                <BitmapImage UriSource="{Binding UserPic}"/>
                                            </Image.Source>
                                        </Image>

                                        <!-- Comment Content -->
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding User}" FontWeight="Bold" Foreground="#d1d5db"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Width="140" Foreground="#d1d5db"/>
                                            <TextBlock Text="{Binding CreatedDateTime}" FontSize="10" Foreground="#d1d5db"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Version}" Foreground="#d1d5db" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>
