<Window x:Class="AssetManager.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="500" Width="700">

    <Grid>
        <!-- Define Grid Rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Upload Button -->
            <RowDefinition Height="Auto"/> <!-- Project Dropdown -->
            <RowDefinition Height="Auto"/> <!-- Model Dropdown -->
            <RowDefinition Height="Auto"/> <!-- Refresh Button -->
            <RowDefinition Height="Auto"/> <!-- View Comments Button -->
            <RowDefinition Height="Auto"/> <!-- Comment List -->
            <RowDefinition Height="Auto"/> <!-- Comment Input and Post Button -->
            <RowDefinition Height="Auto"/> <!-- Logout Button -->  <!-- ✅ ADDED THIS -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Upload File Button -->
        <Button x:Name="BtnUploadFile" 
                Content="Upload File" 
                Width="200" Height="40" 
                Click="BtnUploadFile_Click"
                Grid.Row="0" HorizontalAlignment="Center" Margin="10"/>

        <!-- Project Selection Section -->
        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock Text="Project Selection:" />
            <ComboBox Name="ProjectComboBox" 
                      SelectionChanged="ProjectComboBox_SelectionChanged" 
                      Width="300" Height="30" />
        </StackPanel>

        <!-- Model Dropdown Section -->
        <StackPanel Grid.Row="2" Margin="10">
            <TextBlock Text="Model Selection:" />
            <ComboBox x:Name="ModelComboBox" 
                      Width="300" Height="30" />
        </StackPanel>

        <!-- Refresh Models Button -->
        <Button x:Name="BtnRefreshModels" 
                Content="Refresh Models" 
                Width="150" Height="30" 
                Click="BtnRefreshModels_Click"
                Grid.Row="3" HorizontalAlignment="Center" Margin="10"/>
        <Button x:Name="BtnLogout" 
                Content="Log Out" 
                Width="200" Height="40" 
                Click="BtnLogout_Click"
                Grid.Row="4" HorizontalAlignment="Center" Margin="30"/>
        <!-- View Comments Button -->
        <Button x:Name="BtnDownloadModel" 
                Content="Download" 
                Width="150" Height="30" 
                Click="BtnDownloadModel_Click"
                Grid.Row="4" HorizontalAlignment="Center" Margin="10"/>
        <!-- <Button x:Name="BtnViewComment"  -->
        <!--         Content="View Comments"  -->
        <!--         Width="200" Height="40"  -->
        <!--         Click="BtnViewComment_Click" -->
        <!--         Grid.Row="5" HorizontalAlignment="Center" Margin="10"/> -->

        <!-- Comments List -->
        <ListBox x:Name="ListComments" Width="450" Height="200" 
                 Grid.Row="6" HorizontalAlignment="Center" Margin="10"
                 Visibility="Hidden">
            <ListBoxItem>Comments</ListBoxItem>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="10" />
                        </Grid.ColumnDefinitions>
                        <Label Content="{Binding User}" />
                        <Label Grid.Column="1" Content="{Binding Content}" />
                        <Label Grid.Column="2" Content="{Binding CreatedDateTime}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Comment Input -->
        <TextBox x:Name="CommentContent" Text="Add a comment"
                 Width="200" Height="40" Grid.Row="7"
                 HorizontalAlignment="Center" Margin="10"
                 Visibility="Hidden"/>

        <!-- Post Comment Button -->
        <!-- <Button x:Name="BtnAddComment"  -->
        <!--         Content="Post Comment"  -->
        <!--         Width="200" Height="40" -->
        <!--         Click="BtnAddComment_Click" -->
        <!--         Grid.Row="8" HorizontalAlignment="Center" Margin="10" -->
        <!--         Visibility="Hidden"/> -->

        <!-- ✅ Log Out Button (Moved to Row 7) -->
       
    
    </Grid>
</Window>
