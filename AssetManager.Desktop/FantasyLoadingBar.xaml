<UserControl x:Class="AssetManager.Desktop.FantasyLoadingBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AssetManager.Desktop"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="500">

    <UserControl.Resources>
        <!-- Gradient for the background -->
        <LinearGradientBrush x:Key="ScrollBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2C2C2C" Offset="0"/>
            <GradientStop Color="#3A3A3A" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient for the progress indicator to match Autodesk orange/purple theme -->
        <LinearGradientBrush x:Key="ProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F25505" Offset="0.0"/>
            <GradientStop Color="#6A0DAD" Offset="0.7"/>
            <GradientStop Color="#F25505" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Storyboard for the sparkle animation -->
        <Storyboard x:Key="SparkleAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" Storyboard.TargetName="SparkleElement">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" Storyboard.TargetName="SparkleElement">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0.5"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" Storyboard.TargetName="SparkleElement">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="1.2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0.5"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SparkleAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Border CornerRadius="10" Background="{StaticResource ScrollBackgroundBrush}" BorderBrush="#6A6A6A" BorderThickness="1" Padding="3">
            <!-- Ancient scroll appearance with decorative ends -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>

                <!-- Left scroll end -->
                <Border Grid.Column="0" Background="#6A6A6A" CornerRadius="5" Margin="0,5">
                    <Path Data="M 5,0 L 10,5 L 5,10 L 0,5 Z" Fill="#3A3A3A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Progress bar area -->
                <Grid Grid.Column="1" Margin="2,0" x:Name="ProgressBarContainer">
                    <!-- Rune symbols on background -->
                    <Canvas ClipToBounds="True">
                        <TextBlock Text="⚔ ✧ ⚜ ✦ ⚔ ✧ ⚜ ✦ ⚔ ✧ ⚜ ✦ ⚔ ✧ ⚜ ✦ ⚔ ✧ ⚜ ✦" 
                                 Foreground="#4A4A4A" FontSize="16" FontFamily="Segoe UI Symbol"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Canvas.Top="10" Canvas.Left="20"/>
                    </Canvas>

                    <!-- Actual progress bar -->
                    <Border x:Name="ProgressIndicator" CornerRadius="5" HorizontalAlignment="Left" 
                            Background="{StaticResource ProgressBrush}"
                            Width="0">

                        <!-- Magical sparkle effect -->
                        <Path x:Name="SparkleElement" Data="M 0,10 L 5,0 L 10,10 L 0,5 L 10,5 L 0,10 Z" Fill="White" 
                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Border>

                    <!-- Progress text -->
                    <TextBlock x:Name="ProgressText" Text="0%" 
                               Foreground="White" FontFamily="Monotype Corsiva" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Right scroll end -->
                <Border Grid.Column="2" Background="#6A6A6A" CornerRadius="5" Margin="0,5">
                    <Path Data="M 5,0 L 10,5 L 5,10 L 0,5 Z" Fill="#3A3A3A" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>