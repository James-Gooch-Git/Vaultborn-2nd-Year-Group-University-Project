<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fantasy Card Control Template -->
    <ControlTemplate x:Key="FantasyCardTemplate" TargetType="ContentControl">
        <Grid>
            <!-- Base Card Shape -->
            <Border CornerRadius="7" Background="#0F0F1A">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.7" Color="Black"/>
                </Border.Effect>
            </Border>
            
            <!-- Ornate Card Frame -->  
            <Grid>
                <!-- Inner Card Area (Slightly Inset) -->
                <Border Margin="5" CornerRadius="5" Background="#1A1A2E">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                </Border>
                
                <!-- Corner Ornaments -->
                <Path Data="M0,20 C0,8 8,0 20,0 L20,5 C10,5 5,10 5,20 Z" 
                      Fill="#C0A062" Stretch="None" 
                      HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Path Data="M0,0 L20,0 C32,0 40,8 40,20 L35,20 C35,10 30,5 20,5 Z" 
                      Fill="#C0A062" Stretch="None" 
                      HorizontalAlignment="Right" VerticalAlignment="Top"/>
                <Path Data="M0,0 L0,20 C0,32 8,40 20,40 L20,35 C10,35 5,30 5,20 Z" 
                      Fill="#C0A062" Stretch="None" 
                      HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                <Path Data="M40,0 L40,20 C40,32 32,40 20,40 L20,35 C30,35 35,30 35,20 Z" 
                      Fill="#C0A062" Stretch="None" 
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                
                <!-- Side Ornaments -->
                <Border Width="3" Background="#C0A062" 
                        Margin="10,25,0,25" HorizontalAlignment="Left" 
                        BorderThickness="0,1,0,1" BorderBrush="#E6D9B2"/>
                <Border Width="3" Background="#C0A062" 
                        Margin="0,25,10,25" HorizontalAlignment="Right"
                        BorderThickness="0,1,0,1" BorderBrush="#E6D9B2"/>
                
                <!-- Content Area for Image -->
                <Grid Margin="20,20,20,45">
                    <Border Background="#1E1E30" CornerRadius="3" 
                            BorderBrush="#C0A062" BorderThickness="1">
                        <!-- Image Content Presenter -->
                        <ContentPresenter x:Name="ImageContent"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Magical Glow Effect (can toggle based on state) -->
                    <Border Background="Transparent" CornerRadius="3" 
                            BorderBrush="#C0A06244" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="10" 
                                             Color="#80C0A062" Opacity="0.6"/>
                        </Border.Effect>
                    </Border>
                </Grid>
                
                <!-- Card Name Area -->
                <Border Height="40" VerticalAlignment="Bottom" Margin="15,0,15,10"
                        Background="#1E1E30" CornerRadius="3"
                        BorderBrush="#C0A062" BorderThickness="1">
                    <TextBlock x:Name="CardName"
                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}"
                               FontFamily="Gabriola" FontSize="16" FontWeight="Bold"
                               Foreground="#E6D9B2" TextAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="5,0"/>
                </Border>
                
                <!-- Decorative Runes -->
                <Canvas>
                    <!-- Top Rune -->
                    <Path Data="M5,0 L12,5 L19,0 L12,-5 Z" Fill="#C0A062" Canvas.Left="65" Canvas.Top="15"/>
                    <!-- Bottom Rune -->
                    <Path Data="M5,0 L0,7 L5,14 L10,7 Z" Fill="#C0A062" Canvas.Left="70" Canvas.Top="188"/>
                </Canvas>
            </Grid>
        </Grid>
    </ControlTemplate>
    
    <!-- Card Style (For easy application) -->
    <Style x:Key="FantasyCardStyle" TargetType="ContentControl">
        <Setter Property="Template" Value="{StaticResource FantasyCardTemplate}"/>
        <Setter Property="Width" Value="150"/>
        <Setter Property="Height" Value="210"/>
        <Setter Property="Margin" Value="5"/>
        <Style.Triggers>
            <!-- Hover Effect -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Panel.ZIndex" Value="10"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="5" BlurRadius="15" Opacity="0.6" Color="#C0A062"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <!-- Selected Effect (Using IsEnabled as a toggle) -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.7"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Example of how to use the card in collection generation -->
    <DataTemplate x:Key="FantasyCardDataTemplate">
        <ContentControl Style="{StaticResource FantasyCardStyle}"
                        Tag="{Binding Name}"
                        Cursor="Hand">
            <Image Source="{Binding ImageSource}" 
                   Stretch="UniformToFill" 
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </ContentControl>
    </DataTemplate>
</ResourceDictionary>