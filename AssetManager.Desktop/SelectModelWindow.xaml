<Window x:Class="AssetManager.Desktop.SelectModelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Model" Height="500" Width="800" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*" /> <!-- Projects and Models -->
            <RowDefinition Height="3*" /> <!-- Confirm -->
        </Grid.RowDefinitions>
        
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/CityMarket.png"></ImageBrush>
        </Grid.Background>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" /> <!-- Projects -->
            <ColumnDefinition Width="3*" /> <!-- Models -->
        </Grid.ColumnDefinitions>

        <ListBox x:Name="BGListBox"
            DisplayMemberPath="Name" 
            Margin="50, 80,10, 60" 
            BorderBrush="#FFD700" BorderThickness="1" 
            Background="#FF000000" 
            Opacity="0.5" >
        </ListBox>
        
        <!-- Projects List -->
        <ListBox x:Name="ProjectListBox" 
                 SelectionChanged="ProjectListBox_SelectionChanged"
                 DisplayMemberPath="Name"
                 Margin="50, 80,10, 60"
                 BorderBrush="#FFD700" BorderThickness="1"
                 Background="Transparent"
                 Foreground="White"/>
        
        <TextBlock Text="Select Project" FontWeight="Bold" 
                   Foreground="Azure" Margin="50,0, 0, 220" Height="40"
                   FontSize="16"/>
        
        <!-- Models List -->
        
        <ListBox x:Name="BGListBox2" Grid.Column="1"
                 SelectionMode="Single"
                 Margin="10, 80, 50, 60"
                 BorderBrush="#FFD700" BorderThickness="1"
                 Background="#FF000000"
                 Opacity="0.5">
        </ListBox>
        
        <ListBox x:Name="ModelListBox" Grid.Column="1"
                 SelectionMode="Single"
                 Margin="10, 80, 50, 60"
                 BorderBrush="#FFD700" BorderThickness="1"
                 Background="Transparent"
                 Foreground="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <TextBlock Grid.Column="1" Text="Select Model" FontWeight="Bold" 
                   Foreground="Azure" Margin="10,0, 0, 220" Height="40"
                   FontSize="16"/>

        <!-- Confirm Selection Button -->
        <Button Grid.Column="1" Grid.Row="1"
                Width="100" Height="80"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0, 0, 80, 70"
                Background="Transparent"
                BorderThickness="0"
                Click="SelectModelButton_Click">
                <Grid>
                    <TextBlock Text="..........................." HorizontalAlignment="Center" VerticalAlignment="Center" Background="Black" Opacity="0.6" />
                    <TextBlock Text="Confirm" Foreground="Azure" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                      <Image Source = "pack://application:,,,/Assets/buttongold.png" Stretch="Fill"/> 
                </Grid>
        </Button>   
    </Grid>
</Window>