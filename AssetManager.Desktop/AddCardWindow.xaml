<Window x:Class="AssetManager.Desktop.AddCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fantasy Card Preview"
        WindowStartupLocation="CenterScreen"
        Width="500" Height="350"
        ResizeMode="NoResize">
    
    <Window.Resources>
        
        <!-- Fantasy-themed styles -->
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1E0A30" Offset="0"/>
            <GradientStop Color="#261447" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid>
        <Grid.Background>  
            <ImageBrush ImageSource="pack://application:,,,/Assets/addCardBG.png"></ImageBrush>  
        </Grid.Background> 
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" /> <!-- Card Preview (Larger) -->
            <ColumnDefinition Width="3*" /> <!-- Stats & Buttons -->
        </Grid.ColumnDefinitions>
        
        <!-- Fantasy Card Preview -->
        <Grid Grid.Column="0">
            <ContentControl Style="{StaticResource FantasyCardStyle}"
                            Tag="{Binding SelectedCardName}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0, 50"
                            Panel.ZIndex="2">
                <Image x:Name="SelectedCardImage"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </ContentControl>
        </Grid>

        <!-- Stats & Input Fields -->
        <Grid Grid.Column="1" Margin="30">
            <StackPanel>
                <StackPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="TextBlock.Foreground" Value="Gainsboro" />
                        <!-- <Setter Property="TextBox.Background" Value="CornflowerBlue" /> -->
                    </Style>
                </StackPanel.Resources>
                
                <StackPanel MinWidth="250" MaxWidth="250">
                    <TextBlock Text="Card Name:" FontWeight="Bold" Margin="0,15, 0, 0"/>
                    <TextBox x:Name="CardNameTextBox" Margin="0,0, 30, 10" Background="AntiqueWhite" 
                             BorderThickness="0" Width="210" HorizontalAlignment="Left"/>

                    <TextBlock Text="3D Model:" FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 10">
                        <TextBlock x:Name="ModelTextBox" Margin="0,0, 0, 10" Background="AntiqueWhite" Foreground="DimGray" Width="190"/>
                        <Border BorderThickness="0" BorderBrush="AntiqueWhite" Height="16" VerticalAlignment="Top">
                            <Button Content="📁" 
                                    FontSize="10"
                                    Width="20" Height="23"
                                    Margin="0,0,0,0"
                                    Background="AntiqueWhite"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ToolTip="Select model from Fusion"
                                    Click="BrowseModelsButton_Click"/>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Text="Image URL:" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 10">
                        <TextBox x:Name="ImageUrlTextBox" Margin="0,0, 0, 10" Background="AntiqueWhite" Width="190" BorderThickness="0"/>
                        <Border BorderThickness="0" BorderBrush="AntiqueWhite" Height="16" VerticalAlignment="Top">
                            <Button Content="📷" 
                                    FontSize="10"
                                    Width="20" Height="23"
                                    Margin="0,0,0,0"
                                    Background="AntiqueWhite"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ToolTip="Load image from local folder"
                                    Click="LoadLocalImageButton_Click"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Description:" FontWeight="Bold"/>
                    <TextBox x:Name="DescriptionTextBox" Margin="0,0, 0, 0" Background="AntiqueWhite" Width="210"
                             Height="40" BorderThickness="0" HorizontalAlignment="Left"/>
                </StackPanel>
                
                <Button Content="Add Card" Click="SubmitCard_Click" 
                        Margin="10,20,10,0" Background="#540754" Foreground="White" Width="60"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
