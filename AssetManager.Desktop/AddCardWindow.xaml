<Window x:Class="AssetManager.Desktop.AddCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Card" Height="400" Width="300"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Card Name:" FontWeight="Bold"/>
            <TextBox x:Name="CardNameTextBox" Margin="0,5"/>

            <TextBlock Text="Description:" FontWeight="Bold"/>
            <TextBox x:Name="DescriptionTextBox" Margin="0,5"/>

            <TextBlock Text="Image URL:" FontWeight="Bold"/>
            <TextBox x:Name="ImageUrlTextBox" Margin="0,5"/>

            <TextBlock Text="3D Model URL:" FontWeight="Bold"/>
            <TextBox x:Name="ModelUrlTextBox" Margin="0,5"/>

            <Button Content="Add Card" Click="SubmitCard_Click" 
                    Margin="10,20,10,0" Background="Green" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>