<Window x:Class="AssetManager.Desktop.DeckView" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arcane Deck Viewer" Height="600" Width="900">
    
    <Window.Resources>
        
        <!-- Fantasy-themed styles -->
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1E0A30" Offset="0"/>
            <GradientStop Color="#261447" Offset="1"/>
        </LinearGradientBrush>
        
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF0AA"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="15" Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Gabriola"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="1" BlurRadius="3" Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Baskerville Old Face"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="1" BlurRadius="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StatsTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Baskerville Old Face"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,2"/>
        </Style>
        

    </Window.Resources>
    
    <Grid>
        <Grid.Background>  
            <ImageBrush ImageSource="pack://application:,,,/Assets/deckBG3.png"></ImageBrush>  
        </Grid.Background> 
        <!-- Main UI Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" /> <!-- Enlarged Card Display -->
            <RowDefinition Height="1.2*" /> <!-- Card Selection Bar -->
        </Grid.RowDefinitions>

        <!-- Selected Card Display -->
        <Grid Grid.Row="0" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" /> <!-- Card Image -->
                <ColumnDefinition Width="3*" /> <!-- Description -->
            </Grid.ColumnDefinitions>
            
            <!-- Enlarged Selected Card -->
            <Grid Grid.Column="0">
                <!-- Animated Glowing Runes (simulated with ellipses) -->
                <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" Height="300" Panel.ZIndex="1">
                    <Ellipse Width="270" Height="270" Canvas.Left="15" Canvas.Top="15" Stroke="#9370DB" StrokeThickness="1" Opacity="0.6">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.2" To="0.8" Duration="0:0:2"
                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="250" Height="250" Canvas.Left="25" Canvas.Top="25" Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="5,5">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.8" To="0.2" Duration="0:0:3"
                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Canvas>
            
                <!-- Button Panel Above Enlarged Image -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="20,0,0,0"
                            Panel.ZIndex="5">
            
                    <!-- View in 3D Button -->
                    <Border Background="#333333" 
                            Width="36" Height="36" 
                            CornerRadius="10" 
                            Margin="0,0,10,0">
                        <Button Background="Transparent"
                                ToolTip="View in 3D"
                                BorderThickness="0"
                                Click="View3DButton_Click">
                                
                        </Button>
                    </Border>

                    <!-- Expand Fullscreen Button -->
                    <Border Background="#333333" 
                            Width="36" Height="36" 
                            CornerRadius="10">
                        <Button Background="Transparent"
                                ToolTip="View Fullscreen"
                                BorderThickness="0">
                            
                        </Button>
                    </Border>
                </StackPanel>
                <!-- Card Image -->
        <!-- Enlarged Fantasy Card -->
        <ContentControl Style="{StaticResource FantasyCardStyle}"
                        Width="500" Height="520"
                        Tag="{Binding SelectedCardName}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Panel.ZIndex="2">
            <Image x:Name = "SelectedCardImage"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </ContentControl>
            </Grid>

            <!-- Card Details -->
            <Border Grid.Column="1" Margin="60" Panel.ZIndex="2" 
                    Background="#1A000000" 
                    BorderBrush="#FFD700" 
                    BorderThickness="0" 
                    CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="5" BlurRadius="10" Opacity="0.7"/>
                </Border.Effect>
                <StackPanel Margin="15">
                    <!-- Scroll Decoration Top -->
                    <Path Data="M0,0 C20,-5 40,5 60,0 C80,-5 100,5 120,0" 
                          Stroke="#FFD700" 
                          StrokeThickness="2" 
                          Margin="0,0,0,10"
                          HorizontalAlignment="Center" 
                          Width="120"
                          Height="1"/>
                    
                    <!-- Card Name -->
                    <TextBlock x:Name="SelectedCardName"
                               FontSize="28"
                               Text="Select a Card"
                               Style="{StaticResource HeaderTextStyle}"
                               TextAlignment="Center"/>
                    
                    <!-- Divider -->
                    <Border Height="0.4" 
                            Background="#FFD700" 
                            BorderThickness="0.1"
                            Margin="40,0, 40, 20" 
                            Opacity="0.7"/>
                    
                    <!-- Card Description -->
                    <TextBlock x:Name="SelectedCardDescription"
                               FontSize="16"
                               Text="Ancient knowledge awaits your selection..."
                               Style="{StaticResource DescriptionTextStyle}"
                               Margin="0,10,0,15"/>
                    
                    <!-- Card Stats -->
                    <Border Background="#1A000000" 
                            BorderBrush="#FFD700" 
                            BorderThickness="0.1" 
                            CornerRadius="5" 
                            Padding="10">
                        <StackPanel x:Name="SelectedCardStatsPanel">
                            <!-- Stats will be added dynamically here -->
                        </StackPanel>
                    </Border>
                    
                    <!-- Scroll Decoration Bottom -->
                    <Path Data="M0,0 C20,5 40,-5 60,0 C80,5 100,-5 120,0" 
                          Stroke="#FFD700" 
                          StrokeThickness="2" 
                          Margin="0,10,0,0"
                          HorizontalAlignment="Center" 
                          Width="120"
                          Height="1"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Deck of Cards (Bottom Row) -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="#1E0A30"
                BorderThickness="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="250">
                <StackPanel x:Name="CardListPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="10">
                    <!-- Cards will be added dynamically here -->
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        
        <ItemsControl x:Name="DeckRow">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl Style="{StaticResource FantasyCardStyle}"
                                    Tag="{Binding Name}"
                                    Cursor="Hand">
                        <Image Source="{Binding ImageSource}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </ContentControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="1" HorizontalAlignment="Right" Margin="10,0,30,0">
            <Button x:Name="AddCardButton"
                    Width="150" Height="210"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="AddCardButton_Click">
                <Grid>
                    <!-- Card Background -->
                    <Border CornerRadius="7" Background="#0F0F1A" Width="150" Height="210">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.7" Color="Black"/>
                        </Border.Effect>
                    </Border>

                    <!-- Inner Card -->
                    <Border Margin="5" CornerRadius="5" Background="#1A1A2E" Width="140" Height="200">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                    </Border>

                    <!-- Plus Symbol -->
                    <TextBlock Text="+" 
                               FontSize="48" FontWeight="Bold"
                               Foreground="#C0A062"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Button>
        </Grid>

    </Grid>
</Window>
