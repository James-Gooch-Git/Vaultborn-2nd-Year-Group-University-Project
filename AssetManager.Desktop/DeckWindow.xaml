<Window x:Class="AssetManager.Desktop.DeckView" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arcane Deck Viewer" Height="600" Width="900">
    
    <Window.Resources>
        <!-- Fantasy-themed styles -->
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1E0A30" Offset="0"/>
            <GradientStop Color="#261447" Offset="1"/>
        </LinearGradientBrush>
        
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF0AA"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="15" Opacity="0.7"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Gabriola"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="1" BlurRadius="3" Opacity="0.7"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Baskerville Old Face"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="1" BlurRadius="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StatsTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Baskerville Old Face"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,2"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- Main UI Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" /> <!-- Enlarged Card Display -->
            <RowDefinition Height="1*" /> <!-- Card Selection Bar -->
        </Grid.RowDefinitions>
        
        <!-- Background Image -->
        <!-- <Image Source="pack://application:,,,/Resources/fantasy-parchment-background.jpg"  -->
        <!--        Stretch="Fill"  -->
        <!--        Opacity="0.1"/> -->

        <!-- Selected Card Display -->
        <Grid Grid.Row="0" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" /> <!-- Card Image -->
                <ColumnDefinition Width="3*" /> <!-- Description -->
            </Grid.ColumnDefinitions>

            <!-- Enlarged Selected Card -->
            <Grid Grid.Column="0">
                <!-- Magic Circle Behind Card -->
                <Ellipse Width="280" Height="280" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center"
                         Panel.ZIndex="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#3F2684" Offset="0"/>
                            <GradientStop Color="#1E0A30" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Animated Glowing Runes (simulated with ellipses) -->
                <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" Height="300" Panel.ZIndex="1">
                    <Ellipse Width="270" Height="270" Canvas.Left="15" Canvas.Top="15" Stroke="#9370DB" StrokeThickness="1.5">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.2" To="0.8" Duration="0:0:2"
                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="250" Height="250" Canvas.Left="25" Canvas.Top="25" Stroke="#FFD700" StrokeThickness="1" StrokeDashArray="5,5">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="Opacity"
                                            From="0.8" To="0.2" Duration="0:0:3"
                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Canvas>
                
                <!-- Card Image -->
                <Image x:Name="SelectedCardImage"
                       Width="230" Height="330"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Panel.ZIndex="2"/>

                <!-- Ornate Frame -->
                <!-- <Border Width="250" Height="350" -->
                <!--         BorderThickness="12" -->
                <!--         HorizontalAlignment="Center" -->
                <!--         VerticalAlignment="Center" -->
                <!--         Panel.ZIndex="3"> -->
                <!--     <Border.BorderBrush> -->
                <!--         <ImageBrush ImageSource="pack://application:,,,/Resources/ornate-gold-frame_1156559-2825.jpg"  -->
                <!--                     Stretch="Fill"  -->
                <!--                     TileMode="None"/> -->
                <!--     </Border.BorderBrush> -->
                <!--     <Border.Effect> -->
                <!--         <DropShadowEffect Color="#FFD700" ShadowDepth="0" BlurRadius="15" Opacity="0.7"/> -->
                <!--     </Border.Effect> -->
                <!-- </Border> -->
            </Grid>

            <!-- Card Details -->
            <Border Grid.Column="1" Margin="20" Panel.ZIndex="2" 
                    Background="#1A000000" 
                    BorderBrush="#FFD700" 
                    BorderThickness="1" 
                    CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" ShadowDepth="5" BlurRadius="10" Opacity="0.7"/>
                </Border.Effect>
                <StackPanel Margin="15">
                    <!-- Scroll Decoration Top -->
                    <Path Data="M0,0 C20,-5 40,5 60,0 C80,-5 100,5 120,0" 
                          Stroke="#FFD700" 
                          StrokeThickness="2" 
                          Margin="0,0,0,10"
                          HorizontalAlignment="Center" 
                          Width="120"/>
                    
                    <!-- Card Name -->
                    <TextBlock x:Name="SelectedCardName"
                               FontSize="28"
                               Text="Select a Card"
                               Style="{StaticResource HeaderTextStyle}"
                               TextAlignment="Center"/>
                    
                    <!-- Divider -->
                    <Border Height="2" 
                            Background="#FFD700" 
                            Margin="40,10" 
                            Opacity="0.7"/>
                    
                    <!-- Card Description -->
                    <TextBlock x:Name="SelectedCardDescription"
                               FontSize="16"
                               Text="Ancient knowledge awaits your selection..."
                               Style="{StaticResource DescriptionTextStyle}"
                               Margin="0,10,0,15"/>
                    
                    <!-- Card Stats -->
                    <Border Background="#1A000000" 
                            BorderBrush="#FFD700" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="10">
                        <StackPanel x:Name="SelectedCardStatsPanel">
                            <!-- <StackPanel.Resources> -->
                            <!--     <Style TargetType="TextBlock" BasedOn="{StaticResource StatsTextStyle}"/> -->
                            <!-- </StackPanel.Resources> -->
                        </StackPanel>
                    </Border>
                    
                    <!-- Scroll Decoration Bottom -->
                    <Path Data="M0,0 C20,5 40,-5 60,0 C80,5 100,-5 120,0" 
                          Stroke="#FFD700" 
                          StrokeThickness="2" 
                          Margin="0,10,0,0"
                          HorizontalAlignment="Center" 
                          Width="120"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Deck of Cards (Bottom Row) -->
        <Border Grid.Row="1" 
                Background="#26000000" 
                BorderBrush="#FFD700" 
                BorderThickness="1,1,1,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <StackPanel x:Name="CardListPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="10">
                    <!-- Cards will be added dynamically here -->
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
