<Window x:Class="AssetManager.Desktop.ListDeckPrompt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:md="clr-namespace:MaterialDesignThemes.Wpf;assembly=MaterialDesignThemes.Wpf"
        Title="New Deck" Height="300" Width="300" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        
        <!-- Fantasy-themed styles -->
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1E0A30" Offset="0"/>
            <GradientStop Color="#261447" Offset="1"/>
        </LinearGradientBrush>
        
        <Style x:Key="DescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Baskerville Old Face"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" ShadowDepth="1" BlurRadius="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
        

        
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Assets/addCardBG.png"></ImageBrush>
        </Grid.Background>
        <!-- TextBox for Price Input -->
        <StackPanel>
            <TextBlock
                Text="Description:"
                FontSize="16" 
                FontWeight="Bold" 
                Foreground="White" 
                Margin="0, 30, 0, 0"
                HorizontalAlignment="Center"
                Style="{StaticResource DescriptionTextStyle}"
                />
            
            <TextBox x:Name="DescriptionField"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top"
                     Margin="0,0,0,10"
                     Height="80"
                     Width="180"
                     />
            
            <TextBlock
                Text="Price:"
                FontSize="16" 
                FontWeight="Bold" 
                Foreground="White" 
                Margin="0, 0, 0, 0"
                HorizontalAlignment="Center"
                Style="{StaticResource DescriptionTextStyle}"
                />
            <TextBox x:Name="PriceField"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top"
                     Margin="0,0,0,10"
                     Height="30"
                     Width="120"/>

            <!-- StackPanel to hold the buttons side by side -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,0">
                <!-- Cancel Button -->
                <Button Content="Cancel" Width="50" Height="20" Margin="5" Click="Cancel_Click" Foreground="Tomato"/>

                <!-- Ok Button -->
                <Button Content="Ok" Width="50" Height="20" Margin="5" Click="SubmitListing_Click" Foreground="SeaGreen"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>